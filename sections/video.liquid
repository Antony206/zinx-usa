<section class="video-section" id="video-section">
  <div class="video-section__container container">
    <div class="video-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="video-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="video-section__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="video-section__wrapper">
      {%- if section.settings.gif_image != blank -%}
        {{ section.settings.gif_image | image_url: width: 1200 | image_tag: class: 'video-section__html5', loading: 'lazy' }}
      {%- else -%}
        <div class="video-section__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          <div class="video-section__placeholder-text">Upload a GIF from your Shopify Files</div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Animated GIF",
  "class": "video-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SEE IT IN ACTION"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Watch How The Magnetic Rack Works"
    },
    {
      "type": "header",
      "content": "GIF Source"
    },
    {
      "type": "image_picker",
      "id": "gif_image",
      "label": "Animated GIF",
      "info": "Upload a GIF image directly from your Shopify files."
    }
  ],
  "presets": [
    {
      "name": "Animated GIF"
    }
  ]
}
{% endschema %}
