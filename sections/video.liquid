<section class="video-section" id="video-section">
  <div class="video-section__container container">
    <div class="video-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="video-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="video-section__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="video-section__wrapper">
      {%- if section.settings.html5_video != blank -%}
        <video 
          class="video-section__html5"
          autoplay
          muted
          loop
          playsinline
          {% if section.settings.cover_image != blank %}poster="{{ section.settings.cover_image | image_url: width: 1200 }}"{% endif %}
        >
          {%- if section.settings.html5_video.sources -%}
            {%- for source in section.settings.html5_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          {%- else -%}
            <source src="{{ section.settings.html5_video }}" type="video/mp4">
          {%- endif -%}
          Your browser does not support the video tag.
        </video>
      {%- else -%}
        <div class="video-section__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          <div class="video-section__placeholder-text">Upload a video from your Shopify Files</div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "class": "video-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SEE IT IN ACTION"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Watch How The Magnetic Rack Works"
    },
    {
      "type": "header",
      "content": "Video Source"
    },
    {
      "type": "video",
      "id": "html5_video",
      "label": "Shopify-hosted video",
      "info": "Select a video directly from your Shopify files."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover Image (for MP4)",
      "info": "Displays before the video plays."
    }
  ],
  "presets": [
    {
      "name": "Video"
    }
  ]
}
{% endschema %}
