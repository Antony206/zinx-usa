<section class="before-after" style="padding: {{ section.settings.padding_y }}px 0; background: {{ section.settings.bg_color }};">
  <div class="container text-center">
    {%- if section.settings.heading != blank -%}
      <h2 style="margin-bottom: 40px;">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="before-after__wrapper" id="before-after-{{ section.id }}">
      <div class="before-after__image-container">
        <!-- Before Image (Background) -->
        {%- if section.settings.image_before != blank -%}
          <img src="{{ section.settings.image_before | image_url: width: 1200 }}" alt="Before" class="before-after__img before-after__img--before">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'before-after__placeholder' }}
        {%- endif -%}

        <!-- After Image (Foreground, clipped) -->
        <div class="before-after__foreground" id="ba-foreground-{{ section.id }}">
          {%- if section.settings.image_after != blank -%}
            <img src="{{ section.settings.image_after | image_url: width: 1200 }}" alt="After" class="before-after__img before-after__img--after">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'before-after__placeholder before-after__img--after' }}
          {%- endif -%}
        </div>

        <!-- Slider Handle -->
        <div class="before-after__handle" id="ba-handle-{{ section.id }}">
          <div class="before-after__handle-line"></div>
          <div class="before-after__handle-btn">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline><polyline points="21 18 15 12 21 6"></polyline><polyline points="3 18 9 12 3 6" transform="matrix(-1 0 0 1 12 0)"></polyline></svg>
          </div>
        </div>

        <!-- Labels -->
        <span class="before-after__label before-after__label--before">Before</span>
        <span class="before-after__label before-after__label--after">After ZINX</span>
      </div>

      <input type="range" min="0" max="100" value="50" class="before-after__slider" id="ba-slider-{{ section.id }}" aria-label="Percentage of before photo shown">
    </div>
  </div>
</section>

<style>
.before-after__wrapper {
  position: relative;
  max-width: 900px;
  margin: 0 auto;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
}
.before-after__image-container {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
  background: #000;
  overflow: hidden;
}
.before-after__placeholder { width: 100%; height: 100%; display: block; fill: #ddd; background: #eee; }
.before-after__img {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%; object-fit: cover;
  pointer-events: none;
}
.before-after__foreground {
  position: absolute;
  top: 0; left: 0; bottom: 0; right: 0;
  width: 50%;
  overflow: hidden;
}
.before-after__img--after {
  width: 200%; /* Force it to be the exact size of the container, not the wrapper */
  max-width: none;
}
.before-after__slider {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0; cursor: ew-resize; z-index: 20;
}
.before-after__handle {
  position: absolute;
  top: 0; bottom: 0; left: 50%;
  width: 4px; background: var(--color-white);
  transform: translateX(-50%);
  pointer-events: none; z-index: 10;
  box-shadow: 0 0 10px rgba(0,0,0,0.3);
}
.before-after__handle-btn {
  position: absolute;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 40px; height: 40px;
  background: var(--color-white); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: var(--shadow-md); color: var(--color-primary);
}
.before-after__label {
  position: absolute; top: 20px;
  padding: 6px 16px; background: rgba(0,0,0,0.6); color: #fff;
  border-radius: var(--radius-full); font-size: 0.8rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.1em;
  pointer-events: none; z-index: 5;
}
.before-after__label--before { right: 20px; }
.before-after__label--after { left: 20px; }

@media (max-width: 768px) {
  .before-after__image-container { aspect-ratio: 4/5; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const slider = document.getElementById('ba-slider-{{ section.id }}');
  const foreground = document.getElementById('ba-foreground-{{ section.id }}');
  const handle = document.getElementById('ba-handle-{{ section.id }}');
  const afterImg = document.querySelector('#ba-foreground-{{ section.id }} .before-after__img--after');

  if (slider && foreground && handle && afterImg) {
    const updateSlider = () => {
      const val = slider.value;
      foreground.style.width = `${val}%`;
      handle.style.left = `${val}%`;
      // Ensure the after image inside the clipped div maintains 100% of the parent container's width
      afterImg.style.width = `${(100 / val) * 100}%`;
    };
    
    // Initial call
    updateSlider();

    slider.addEventListener('input', updateSlider);
  }
});
</script>

{% schema %}
{
  "name": "Before / After Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Difference in Seconds"
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Before Image (Messy)"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "After Image (Clean ZINX Setup)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f5"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 40, "max": 140, "step": 10, "unit": "px",
      "label": "Vertical Padding", "default": 80
    }
  ],
  "presets": [
    {
      "name": "Before / After Slider"
    }
  ]
}
{% endschema %}
