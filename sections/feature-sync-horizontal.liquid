<section class="feature-sync-h" id="feature-sync-h-{{ section.id }}" style="padding: {{ section.settings.padding_y }}px 0; background: {{ section.settings.bg_color }};">
  <div class="container text-center">
    
    <!-- Top Media Area -->
    <div class="feature-sync-h__media-wrapper">
      {%- for block in section.blocks -%}
        <div class="feature-sync-h__media-item {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title }}" loading="lazy">
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- Navigation Pills -->
    <div class="feature-sync-h__nav-scroll">
      <div class="feature-sync-h__nav">
        {%- for block in section.blocks -%}
          <button class="feature-sync-h__pill {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_svg != blank -%}
              <span class="feature-sync-h__pill-icon">{{ block.settings.icon_svg }}</span>
            {%- endif -%}
            <span class="feature-sync-h__pill-text">{{ block.settings.title }}</span>
          </button>
        {%- endfor -%}
      </div>
    </div>

    <!-- Bottom Description Text Area -->
    <div class="feature-sync-h__text-wrapper">
      {%- for block in section.blocks -%}
        <div class="feature-sync-h__text-item {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}">
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
.feature-sync-h__media-wrapper {
  position: relative;
  width: 100%;
  max-width: 900px;
  aspect-ratio: 16/9;
  margin: 0 auto 40px;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--color-bg-alt);
  box-shadow: var(--shadow-xl);
}
.feature-sync-h__media-item {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  opacity: 0; visibility: hidden;
  transition: opacity 0.5s ease, transform 0.5s ease;
  transform: scale(1.02);
}
.feature-sync-h__media-item.is-active {
  opacity: 1; visibility: visible; transform: scale(1);
}
.feature-sync-h__media-item img, .feature-sync-h__media-item svg {
  width: 100%; height: 100%; object-fit: cover; border-radius: inherit; display: block;
}

.feature-sync-h__nav-scroll {
  width: 100%;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
  margin-bottom: 40px;
}
.feature-sync-h__nav-scroll::-webkit-scrollbar { display: none; }
.feature-sync-h__nav {
  display: inline-flex;
  gap: 12px;
  background: var(--color-bg-alt);
  padding: 8px;
  border-radius: var(--radius-full);
  margin: 0 auto;
}
.feature-sync-h__pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px 24px;
  border-radius: var(--radius-lg);
  color: var(--color-text-muted);
  font-weight: 600;
  font-size: 0.9rem;
  transition: all 0.3s ease;
  min-width: 120px;
}
.feature-sync-h__pill.is-active {
  background: var(--color-primary);
  color: var(--color-white);
  box-shadow: var(--shadow-md);
}
.feature-sync-h__pill:hover:not(.is-active) {
  color: var(--color-primary);
  background: rgba(0,0,0,0.03);
}
.feature-sync-h__pill-icon svg { width: 24px; height: 24px; fill: currentColor; }

.feature-sync-h__text-wrapper {
  position: relative;
  max-width: 700px;
  margin: 0 auto;
  min-height: 100px;
}
.feature-sync-h__text-item {
  position: absolute;
  top: 0; left: 0; width: 100%;
  opacity: 0; visibility: hidden;
  transform: translateY(10px);
  transition: all 0.4s ease;
}
.feature-sync-h__text-item.is-active {
  position: relative;
  opacity: 1; visibility: visible; transform: translateY(0);
}
.feature-sync-h__text-item p {
  font-size: clamp(1.1rem, 2vw, 1.25rem);
  line-height: 1.6;
  color: var(--color-text);
  font-weight: 500;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const section = document.getElementById('feature-sync-h-{{ section.id }}');
  if (!section) return;

  const pills = section.querySelectorAll('.feature-sync-h__pill');
  const mediaItems = section.querySelectorAll('.feature-sync-h__media-item');
  const textItems = section.querySelectorAll('.feature-sync-h__text-item');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const index = pill.getAttribute('data-index');

      // Reset all
      pills.forEach(p => p.classList.remove('is-active'));
      mediaItems.forEach(m => m.classList.remove('is-active'));
      textItems.forEach(t => t.classList.remove('is-active'));

      // Activate current
      pill.classList.add('is-active');
      const targetMedia = section.querySelector(`.feature-sync-h__media-item[data-index="${index}"]`);
      const targetText = section.querySelector(`.feature-sync-h__text-item[data-index="${index}"]`);
      
      if(targetMedia) targetMedia.classList.add('is-active');
      if(targetText) targetText.classList.add('is-active');
    });
  });
});
</script>

{% schema %}
{
  "name": "Feature Sync (Horizontal)",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 40, "max": 140, "step": 10, "unit": "px",
      "label": "Vertical Padding", "default": 100
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 5,
      "settings": [
        {
          "type": "text", "id": "title", "label": "Title"
        },
        {
          "type": "textarea", "id": "text", "label": "Description"
        },
        {
          "type": "image_picker", "id": "image", "label": "Image"
        },
        {
          "type": "html", "id": "icon_svg", "label": "Icon SVG (Optional)", "info": "Paste raw SVG code here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Sync (Horizontal)",
      "blocks": [
        { "type": "tab", "settings": { "title": "Center Stage", "text": "Automatically keeps you centered during video calls." } },
        { "type": "tab", "settings": { "title": "Dual Capture", "text": "Record from both lenses at the same time." } }
      ]
    }
  ]
}
{% endschema %}
