<footer class="minimal-footer">
  <div class="minimal-footer__container container">
    <div class="minimal-footer__content">
      <p class="minimal-footer__copyright">&copy; {{ 'now' | date: "%Y" }} Zinx USA. All rights reserved.</p>
      <div class="minimal-footer__links">
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <span class="divider">|</span>
        <a href="/policies/terms-of-service">Terms of Use</a>
        <span class="divider">|</span>
        <a href="/policies/refund-policy">Sales Policy</a>
      </div>
      <p class="minimal-footer__payment">Payment methods accepted here.</p>
    </div>
  </div>
</footer>

{%- style -%}
  .minimal-footer {
    padding: 40px 0;
    background-color: #f8f9fa;
    border-top: 1px solid #e5e7eb;
    text-align: center;
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.8;
  }
  .minimal-footer__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .minimal-footer__copyright {
    margin-bottom: 8px;
  }
  .minimal-footer__links {
    margin-bottom: 8px;
  }
  .minimal-footer__links a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .minimal-footer__links a:hover {
    color: #111;
  }
  .divider {
    margin: 0 8px;
    color: #d1d5db;
  }
  .minimal-footer__payment {
    font-size: 0.8rem;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Minimal Footer",
  "settings": [],
  "presets": [
    {
      "name": "Minimal Footer"
    }
  ]
}
{% endschema %}
