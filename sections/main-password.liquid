<div class="coming-soon-wrapper animate-fade-up">
  <h1 class="coming-soon__title">{{ section.settings.title }}</h1>
  <p class="coming-soon__text">{{ section.settings.text }}</p>
  
  <div class="coming-soon__form">
    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="prospect, password page">
      <div class="newsletter-form__inner">
        <input type="email" name="contact[email]" placeholder="Email address" required class="newsletter-input">
        <button type="submit" class="btn btn--primary btn--full newsletter-btn">Subscribe</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="form-success" style="color: var(--color-success); margin-top: 10px;">Thanks for subscribing! We'll notify you when we launch.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="form-error" style="color: red; margin-top: 10px;">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {% endform %}
  </div>

  <div class="coming-soon__image-wrapper" style="margin-top: 60px;">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'coming-soon__image' }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'coming-soon__image placeholder-svg' }}
    {% endif %}
  </div>
</div>

<style>
.coming-soon-wrapper {
  max-width: 800px;
  margin: 0 auto;
  padding: 60px 20px;
}
.coming-soon__title {
  font-family: var(--font-heading, 'Inter');
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 24px;
  color: var(--color-primary);
}
.coming-soon__text {
  font-size: 1.1rem;
  color: var(--color-text-muted);
  max-width: 600px;
  margin: 0 auto 40px;
  line-height: 1.6;
}
.newsletter-form__inner {
  display: flex;
  flex-direction: column;
  gap: 16px;
  max-width: 400px;
  margin: 0 auto;
}
.newsletter-input {
  width: 100%;
  padding: 16px 20px;
  border: 1px solid var(--color-border, #ccc);
  border-radius: var(--radius-sm, 4px);
  background: var(--color-bg, #fff);
  font-size: 1rem;
  text-align: center;
  transition: border-color 0.3s;
}
.newsletter-input:focus {
  outline: none;
  border-color: var(--color-primary, #000);
}
.newsletter-btn {
  background: var(--color-primary, #000);
  color: var(--color-bg, #fff);
  padding: 16px 20px;
  border: none;
  border-radius: var(--radius-sm, 4px);
  font-size: 1rem;
  cursor: pointer;
  text-transform: uppercase;
  font-weight: 600;
}
.coming-soon__image {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 0 auto;
  border-radius: var(--radius-lg, 12px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.1);
}
.placeholder-svg {
  width: 100%;
  max-width: 600px;
  height: auto;
  background-color: #f4f4f4;
  border-radius: var(--radius-lg, 12px);
}
</style>

{% schema %}
{
  "name": "Coming Soon",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "COMING SOON"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    }
  ]
}
{% endschema %}
