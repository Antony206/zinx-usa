<header class="header {% if template == 'index' %}header--centered{% endif %}" id="header">
  <div class="header__container container">
    <a href="/" class="header__logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          class="header__logo-img"
          width="200"
          height="auto"
          loading="eager"
        >
      {%- else -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- if template != 'index' -%}
      <nav class="header__nav" id="nav-menu" aria-label="Main navigation">
        <ul class="header__nav-list">
          {%- for link in section.settings.menu.links -%}
            <li class="header__nav-item">
              <a href="{{ link.url }}" class="header__nav-link {% if link.active %}is-active{% endif %}">
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}
  </div>
</header>

<style>
.header--centered .header__container {
  justify-content: center;
}
.header--centered {
  background: transparent;
  border-bottom: none;
  position: absolute;
  width: 100%;
}
</style>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
