<section class="policy-page">
  <div class="policy-page__container container--narrow">
    <h1 class="policy-page__title">{{ page.title }}</h1>
    <div class="policy-page__content rte">
      {{ page.content }}
    </div>
  </div>
</section>

{%- style -%}
  .container--narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 100px 24px;
  }
  .policy-page__title {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 60px;
    text-align: center;
  }
  .policy-page__content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #333;
  }
  .policy-page__content h2 {
    margin-top: 40px;
    margin-bottom: 20px;
    font-size: 1.5rem;
  }
  .policy-page__content p {
    margin-bottom: 24px;
  }
{%- endstyle -%}


{% schema %}
{
  "name": "Policy Page",
  "settings": [],
  "presets": [
    {
      "name": "Policy Page"
    }
  ]
}
{% endschema %}
