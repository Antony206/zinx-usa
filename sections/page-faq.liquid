<section class="faq-page">
  <div class="faq-page__container container--narrow">
    <div class="faq-page__header">
      <h1 class="faq-page__title">{{ section.settings.heading }}</h1>
      <p class="faq-page__subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="faq-page__list">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <details class="faq-details">
            <summary class="faq-summary">
              {{ block.settings.question }}
              <span class="faq-icon"></span>
            </summary>
            <div class="faq-content">
              {{ block.settings.answer }}
            </div>
          </details>
        </div>
      {%- endfor -%}
    </div>

    <div class="faq-page__footer">
      <p>Still have questions?</p>
      <a href="/pages/contact" class="link-minimal">Contact Us</a>
    </div>
  </div>
</section>

{%- style -%}
  .container--narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .faq-page__header {
    text-align: center;
    margin-bottom: 60px;
  }
  .faq-page__title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .faq-page__subtitle {
    font-size: 1.1rem;
    color: #666;
  }
  .faq-item {
    border-bottom: 1px solid #eee;
  }
  .faq-details {
    padding: 24px 0;
  }
  .faq-summary {
    list-style: none;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-icon {
    width: 20px;
    height: 20px;
    position: relative;
    transition: transform 0.3s ease;
  }
  .faq-icon::before, .faq-icon::after {
    content: '';
    position: absolute;
    background: #000;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .faq-icon::before { width: 12px; height: 2px; }
  .faq-icon::after { width: 2px; height: 12px; transition: opacity 0.3s ease; }
  
  .faq-details[open] .faq-icon::after {
    opacity: 0;
  }
  
  .faq-content {
    padding-top: 16px;
    font-size: 1rem;
    line-height: 1.6;
    color: #444;
  }
  .faq-page__footer {
    margin-top: 80px;
    text-align: center;
    padding-top: 40px;
    border-top: 1px solid #eee;
  }
  .link-minimal {
    display: inline-block;
    margin-top: 12px;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
{%- endstyle -%}


{% schema %}
{
  "name": "FAQ Page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "FAQ"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Everything you need to know about our products, shipping, and returns."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Page",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How does the Magnetic Rack attach to my fridge?",
            "answer": "<p>Our rack uses powerful neodymium magnets that attach securely to any magnetic surface, including the sides of most refrigerators, dishwashers, and metal doors. No drilling, screws, or adhesive required — simply place it and it holds firm.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How much weight can the rack hold?",
            "answer": "<p>The ZINX Magnetic Rack can hold up to 15 lbs of items securely. That's plenty for spice jars, utensils, kitchen wraps, and other essentials.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will the magnets scratch my fridge?",
            "answer": "<p>No! Our magnets have a protective soft coating on the contact surface to prevent any scratching or marking. Your fridge stays pristine.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your shipping policy?",
            "answer": "<p>We offer free standard shipping on orders over $50 within the United States. Standard delivery takes 5-8 business days. Expedited shipping options are available at checkout.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day money-back guarantee. If you're not completely satisfied, return the product in its original condition within 30 days for a full refund. No questions asked.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Currently, we ship within the United States only. International shipping will be available soon — stay tuned!</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
