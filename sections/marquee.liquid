<section class="marquee-promo" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; py-2">
  <div class="marquee-promo__wrapper">
    <div class="marquee-promo__content" style="animation-duration: {{ section.settings.speed }}s;">
      {%- for i in (1..10) -%}
        <div class="marquee-promo__text">
          {{ section.settings.text }}
          {%- if section.settings.show_icon -%}
            <span class="marquee-promo__icon">⚡</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
.marquee-promo {
  overflow: hidden;
  white-space: nowrap;
  padding: 10px 0;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}
.marquee-promo__wrapper {
  display: flex;
}
.marquee-promo__content {
  display: flex;
  gap: 40px;
  animation: marquee linear infinite;
}
.marquee-promo__text {
  font-size: {{ section.settings.text_size }}px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  display: flex;
  align-items: center;
  gap: 40px;
}
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
</style>

{% schema %}
{
  "name": "Scrolling Marquee",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "FREE SHIPPING ON ORDERS OVER $50 • 30-DAY GUARANTEE • 10K+ HAPPY CUSTOMERS"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#18181b"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text Size",
      "default": 13
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Lightning Icon Divider",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Scrolling Marquee"
    }
  ]
}
{% endschema %}
