<div id="cart-drawer-overlay" class="cart-drawer-overlay"></div>

<div id="cart-drawer" class="cart-drawer">
  <div class="cart-drawer__header">
    <h3 class="cart-drawer__title">Your Cart (<span id="cart-drawer-count">{{ cart.item_count }}</span>)</h3>
    <button type="button" id="cart-drawer-close" class="cart-drawer__close" aria-label="Close cart">
      {% render 'icon' with 'x' %}
    </button>
  </div>

  <div class="cart-drawer__body">
    <div id="cart-drawer-shipping" class="cart-drawer__shipping" data-threshold="5000">
      <!-- Shipping calculator will be handled via JS -->
      <p class="cart-drawer__shipping-text">You're <strong id="cart-shipping-amount"></strong> away from <strong>FREE SHIPPING!</strong></p>
      <div class="cart-drawer__shipping-bar"><div class="cart-drawer__shipping-progress" id="cart-shipping-progress"></div></div>
    </div>

    <form action="/cart" method="post" id="cart-drawer-form" class="cart-drawer__form">
      <div id="cart-drawer-items" class="cart-drawer__items">
        <!-- Cart items will be loaded via AJAX here -->
      </div>
    </form>
    
    <div id="cart-drawer-empty" class="cart-drawer__empty" style="{% if cart.item_count > 0 %}display:none;{% endif %}">
      <p>Your cart is empty.</p>
      <button type="button" class="btn btn--primary" id="btn-continue-shopping">Continue Shopping</button>
    </div>
  </div>

  <div class="cart-drawer__footer" id="cart-drawer-footer" style="{% if cart.item_count == 0 %}display:none;{% endif %}">
    <div class="cart-drawer__subtotal">
      <span>Subtotal</span>
      <span id="cart-drawer-total">{{ cart.total_price | money }}</span>
    </div>
    <p class="cart-drawer__note">Taxes and shipping calculated at checkout</p>
    <a href="/checkout" class="btn btn--primary btn--full cart-drawer__checkout">Checkout</a>
  </div>
</div>

<style>
.cart-drawer-overlay {
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}
.cart-drawer-overlay.is-open {
  opacity: 1; visibility: visible;
}
.cart-drawer {
  position: fixed;
  top: 0; right: -420px;
  width: 100%; max-width: 400px;
  height: 100vh;
  background: var(--color-white);
  z-index: 1001;
  display: flex;
  flex-direction: column;
  box-shadow: -5px 0 20px rgba(0,0,0,0.1);
  transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.cart-drawer.is-open { right: 0; }
.cart-drawer__header {
  padding: 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--color-border);
}
.cart-drawer__title { font-size: 1.2rem; margin: 0; }
.cart-drawer__close { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: var(--color-bg-alt); transition: var(--transition-fast); }
.cart-drawer__close:hover { background: #e5e7eb; }

.cart-drawer__body {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
}
.cart-drawer__shipping {
  margin-bottom: 24px;
  text-align: center;
  font-size: 0.85rem;
}
.cart-drawer__shipping-bar {
  height: 6px;
  width: 100%;
  background: #e5e7eb;
  border-radius: var(--radius-full);
  margin-top: 8px;
  overflow: hidden;
}
.cart-drawer__shipping-progress {
  height: 100%;
  background: var(--color-success);
  width: 0%;
  transition: width 0.4s ease;
}
.cart-drawer-item {
  display: flex;
  gap: 16px;
  margin-bottom: 24px;
  position: relative;
}
.cart-drawer-item__img {
  width: 80px; height: 80px;
  border-radius: var(--radius-sm);
  background: var(--color-bg-alt);
  object-fit: cover;
}
.cart-drawer-item__info { flex: 1; }
.cart-drawer-item__title { font-weight: 600; font-size: 0.95rem; margin-bottom: 4px; display: block; }
.cart-drawer-item__price { font-weight: 700; color: var(--color-primary); margin-bottom: 8px; }
.cart-drawer-item__qty {
  display: flex; align-items: center;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  width: fit-content;
  height: 32px;
}
.cart-drawer-item__qtybtn { width: 32px; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
.cart-drawer-item__qtyinput { width: 32px; height: 100%; border: none; text-align: center; font-size: 0.85rem; font-weight: 600; padding: 0; border-left: 1px solid var(--color-border); border-right: 1px solid var(--color-border); }
.cart-drawer-item__remove { position: absolute; top: 0; right: 0; color: var(--color-text-muted); font-size: 0.8rem; text-decoration: underline; cursor: pointer; }

.cart-drawer__empty { text-align: center; padding: 40px 0; color: var(--color-text-muted); }

.cart-drawer__footer {
  padding: 24px;
  border-top: 1px solid var(--color-border);
  background: var(--color-bg-alt);
}
.cart-drawer__subtotal {
  display: flex; justify-content: space-between;
  font-size: 1.1rem; font-weight: 700; margin-bottom: 12px;
}
.cart-drawer__note { font-size: 0.8rem; color: var(--color-text-muted); text-align: center; margin-bottom: 16px; }
</style>
